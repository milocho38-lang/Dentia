APP_NAME=Dentia API
APP_ENV=local
APP_DEBUG=true
API_PREFIX=/api
LOG_LEVEL=INFO

# Local PostgreSQL development database.
DATABASE_URL=postgresql+psycopg://dentia:dentia@localhost:5432/dentia

# Authentication.
# Generate a different secret outside the repository for every environment.
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ALGORITHM=HS256
JWT_ISSUER=dentia-api
JWT_AUDIENCE=dentia-web
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=8
SESSION_IDLE_TIMEOUT_MINUTES=60
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_IP_MAX_FAILED_ATTEMPTS=20
AUTH_IP_WINDOW_MINUTES=15
REFRESH_COOKIE_NAME=dentia_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_PATH=/api/auth
