# Dentia operational scripts configuration.
# Copy to scripts/dentia.env for local overrides. Do not store secrets here.

# General
DENTIA_PROJECT_DIR=

# Local Mac
DENTIA_FRONTEND_PORT=3000
DENTIA_BACKEND_PORT=8000
DENTIA_FRONTEND_URL=http://localhost:3000
DENTIA_BACKEND_HEALTH_URL=http://127.0.0.1:8000/health

# Production VPS
DENTIA_PRODUCTION_DIR=/opt/apps/dentia
DENTIA_BACKUP_DIR=/opt/backups/dentia
DENTIA_BACKUP_RETENTION=30
DENTIA_DOMAIN_URL=https://dentiapro.com
DENTIA_PRODUCTION_FRONTEND_URL=http://127.0.0.1:3001
DENTIA_PRODUCTION_BACKEND_HEALTH_URL=http://127.0.0.1:8001/health
DENTIA_FRONTEND_CONTAINER=dentia-frontend
DENTIA_BACKEND_CONTAINER=dentia-backend
DENTIA_DB_CONTAINER=dentia-db
DENTIA_DB_NAME=dentia
DENTIA_DB_USER=dentia
